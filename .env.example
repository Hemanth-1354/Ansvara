# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: Groq API key (get one free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required: Strong random secret for JWT signing
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins (no trailing slash)
# For local dev: http://localhost:3000,http://localhost:5173
# For production: https://your-app.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
